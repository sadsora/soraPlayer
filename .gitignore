.vscode/

#Flutter version management
.fvm/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Code generation (freezed / json_serializable / etc.)
*.g.dart
*.freezed.dart

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android keystore & signing keys — NEVER commit these
*.keystore
*.jks
key.properties

# Windows — auto-generated Flutter plugin files
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake

# macOS (if platform is added later)
macos/Pods/
macos/Flutter/ephemeral/

# iOS (if platform is added later)
ios/Pods/
ios/Flutter/ephemeral/

# Linux (if platform is added later)
linux/flutter/ephemeral/
